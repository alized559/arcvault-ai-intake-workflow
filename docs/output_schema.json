{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArcVaultTriageRecord",
  "type": "object",
  "required": [
    "request_id",
    "source",
    "customer_message",
    "classification",
    "enrichment",
    "decision",
    "summary"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "customer_message": {
      "type": "string"
    },
    "classification": {
      "type": "object",
      "required": ["category", "priority", "confidence"],
      "properties": {
        "category": {
          "type": "string",
          "enum": [
            "Bug Report",
            "Feature Request",
            "Billing Issue",
            "Technical Question",
            "Incident/Outage"
          ]
        },
        "priority": {
          "type": "string",
          "enum": ["Low", "Medium", "High"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["queue", "escalated"],
      "properties": {
        "queue": { "type": "string" },
        "escalated": { "type": "boolean" }
      }
    }
  }
}
